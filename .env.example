# Copy this file to .env.local and adjust the values for your environment.
# .env.local is gitignored and overrides every value in .env.

APP_ENV=dev
APP_SECRET=change-me-to-a-32-char-random-string
APP_DEBUG=1

# Docker (default): the `database` host is resolved by docker-compose.
DATABASE_URL="postgresql://app:app@database:5432/book_library?serverVersion=16&charset=utf8"

# Native (no Docker): use 127.0.0.1 and whatever credentials your local
# Postgres expects, e.g.:
# DATABASE_URL="postgresql://app:app@127.0.0.1:5432/book_library?serverVersion=16&charset=utf8"

LOAD_FIXTURES=1
HTTP_PORT=8080
