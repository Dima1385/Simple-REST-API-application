# Default environment file - safe to commit. Override with .env.local for secrets.
# docker-compose.yml sets DATABASE_URL etc. via `environment:`, so these values
# act only as defaults when the application is run outside Docker (e.g. when
# running `composer install && bin/console doctrine:migrations:migrate` from
# the host with a Postgres reachable at the same host:port).

APP_ENV=dev
APP_SECRET=d6f0e2c4a1b8d3e7f2a9b4c5d6e7f8a9
APP_DEBUG=1

# DATABASE
# Inside Docker the `database` host resolves to the Postgres container.
# When running natively, override DATABASE_URL in .env.local with the host
# and port that match your local Postgres (e.g. 127.0.0.1:5432).
DATABASE_URL="postgresql://app:app@database:5432/book_library?serverVersion=16&charset=utf8"

# Whether the entrypoint should auto-load fixtures (set to 0 in production).
LOAD_FIXTURES=1

# Used by Symfony's router when generating URLs in CLI commands.
DEFAULT_URI=http://localhost
